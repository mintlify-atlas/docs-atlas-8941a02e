  "keyFeatures": [
    "Clean Architecture with Domain-Driven Design",
    "CQRS pattern for command-query separation",
    "Client management with validation",
    "Room reservation and booking system",
    "Dynamic pricing with seasonal rates",
    "Additional services management",
    "Comprehensive audit logging",
    "JWT-based authentication and authorization",
    "AWS integration (S3 storage, SES email)",
    "Swagger/OpenAPI documentation"
  ],
  "publicApiSurface": [
    "POST /api/clientes - Create client",
    "GET /api/clientes - List clients",
    "PUT /api/clientes/{id} - Update client",
    "DELETE /api/clientes/{id} - Delete client",
    "POST /api/reservas - Create reservation",
    "GET /api/reservas - List reservations",
    "PUT /api/reservas/{id} - Update reservation",
    "POST /api/reservas/{id}/confirmar - Confirm reservation",
    "POST /api/reservas/{id}/cancelar - Cancel reservation",
    "GET /api/habitaciones - List rooms",
    "POST /api/habitaciones - Create room",
    "PUT /api/habitaciones/{id}/estado - Update room status",
    "GET /api/tarifas-temporadas - List seasonal rates",
    "POST /api/servicios-adicionales - Create additional service",
    "GET /api/reportes - Generate reports",
    "GET /api/auditoria - Retrieve audit logs"
  ]
